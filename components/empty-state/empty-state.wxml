<view class="empty-state">
  <view class="empty-illustration">{{icon}}</view>
  <text class="empty-title">{{title}}</text>
  <text wx:if="{{description}}" class="empty-description">{{description}}</text>
  <button
    wx:if="{{actionText}}"
    class="empty-action pressable"
    bindtap="handleActionTap"
  >
    {{actionText}}
  </button>
</view>
