:host {
  display: block;
  width: 100%;
}

.empty-state {
  width: 100%;
  min-height: 420rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 56rpx 32rpx 48rpx;
  text-align: center;
  box-sizing: border-box;
}

.empty-illustration {
  width: 92rpx;
  height: 92rpx;
  border-radius: 46rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(184, 92, 56, 0.08);
  color: var(--color-primary);
  font-size: 30rpx;
  font-weight: 700;
}

.empty-title {
  display: block;
  width: 100%;
  margin-top: 22rpx;
  font-size: 34rpx;
  line-height: 1.35;
  font-weight: 700;
  color: var(--color-text-primary);
  word-break: break-word;
}

.empty-description {
  display: block;
  width: 100%;
  max-width: 520rpx;
  margin-top: 12rpx;
  color: var(--color-text-secondary);
  font-size: 24rpx;
  line-height: 1.75;
  word-break: break-word;
}

.empty-action {
  margin-top: 28rpx;
  min-width: 280rpx;
  height: 84rpx;
  line-height: 84rpx;
  padding: 0 32rpx;
  border: none;
  border-radius: 999rpx;
  background: var(--color-primary);
  color: #fffaf2;
  font-size: 26rpx;
  font-weight: 700;
}

.empty-action::after {
  border: none;
}
