.list-card-shell {
  padding: 28rpx;
  box-sizing: border-box;
}

.list-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.list-card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.list-card-action {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-primary);
}
