.data-card-shell {
  padding: 24rpx;
  box-sizing: border-box;
}

.data-label {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.data-value-row {
  margin-top: 12rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 12rpx;
}

.data-value {
  font-size: 36rpx;
  line-height: 1.05;
  font-weight: 700;
  color: var(--color-text-primary);
}

.data-value.emphasized {
  font-size: 54rpx;
  letter-spacing: -1rpx;
}

.data-value.income {
  color: var(--color-income);
}

.data-value.expense {
  color: var(--color-expense);
}

.data-value.balance {
  color: var(--color-balance);
}

.data-meta {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--color-text-secondary);
}
