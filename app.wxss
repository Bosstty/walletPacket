page {
  --color-primary: #b85c38;
  --color-primary-hover: #c96e47;
  --color-primary-active: #8f3f22;
  --color-primary-disabled: #d5a893;
  --color-income: #9b6c44;
  --color-expense: #b85c38;
  --color-balance: #6c5c50;
  --color-bg-page: #f5ecdf;
  --color-bg-card: #fffaf2;
  --color-bg-card-soft: #f2e6d7;
  --color-bg-card-muted: #fbf4ea;
  --color-text-primary: #2f241f;
  --color-text-secondary: #77695f;
  --color-text-tertiary: #a19388;
  --color-line: rgba(47, 36, 31, 0.10);
  --color-line-strong: rgba(47, 36, 31, 0.18);
  --color-danger: #b14f2f;
  --shadow-card: 0 20rpx 50rpx rgba(81, 56, 38, 0.08);
  --shadow-float: 0 24rpx 60rpx rgba(97, 68, 46, 0.14);
  --radius-card: 28rpx;
  --radius-chip: 999rpx;
  --radius-block: 22rpx;
  min-height: 100%;
  background:
    radial-gradient(circle at top right, rgba(184, 92, 56, 0.11), transparent 28%),
    radial-gradient(circle at left 12%, rgba(201, 149, 102, 0.10), transparent 22%),
    var(--color-bg-page);
  color: var(--color-text-primary);
  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

.app-page {
  min-height: 100%;
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

.page-shell {
  padding: 24rpx;
  box-sizing: border-box;
}

.surface-card {
  background: linear-gradient(180deg, rgba(255, 250, 242, 0.98), rgba(252, 246, 238, 0.94));
  border: 1rpx solid var(--color-line);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
}

.data-card {
  background: linear-gradient(180deg, rgba(255, 250, 242, 0.98), rgba(255, 247, 238, 0.94));
  border: 1rpx solid rgba(47, 36, 31, 0.06);
  border-radius: var(--radius-card);
  box-shadow: none;
}

.entry-card {
  background: linear-gradient(180deg, rgba(255, 246, 237, 0.96), rgba(255, 250, 243, 0.92));
  border: 1rpx solid rgba(184, 92, 56, 0.10);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
}

.list-card {
  background: rgba(255, 250, 242, 0.88);
  border: 1rpx solid rgba(47, 36, 31, 0.06);
  border-radius: var(--radius-card);
  box-shadow: none;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
}

.section-subtitle {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.pill-button {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  padding: 0 24rpx;
  line-height: 1;
  border-radius: var(--radius-chip);
  border: none;
  background: var(--color-primary);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

.ghost-button {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  padding: 0 24rpx;
  line-height: 1;
  border-radius: var(--radius-chip);
  background: rgba(255, 255, 255, 0.6);
  color: var(--color-text-primary);
  border: 1rpx solid var(--color-line);
  font-size: 28rpx;
  font-weight: 600;
}

button.pill-button::after,
button.ghost-button::after {
  border: none;
}

.pressable {
  transition: transform 160ms ease, opacity 160ms ease;
}

.pressable:active {
  transform: scale(0.97);
  opacity: 0.96;
}

.text-income {
  color: var(--color-income);
}

.text-expense {
  color: var(--color-expense);
}

.text-balance {
  color: var(--color-balance);
}

.hairline-top {
  border-top: 1rpx solid var(--color-line);
}

.hairline-bottom {
  border-bottom: 1rpx solid var(--color-line);
}

.floating-fab {
  position: fixed;
  right: 28rpx;
  bottom: calc(140rpx + env(safe-area-inset-bottom));
  z-index: 20;
  width: 116rpx;
  height: 116rpx;
  border-radius: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-primary-hover), var(--color-primary-active));
  color: #fffaf2;
  box-shadow: var(--shadow-float);
}

.floating-fab__text {
  font-size: 24rpx;
  font-weight: 700;
}

.budget-track {
  height: 16rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: rgba(119, 105, 95, 0.16);
}

.budget-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, var(--color-primary), var(--color-primary-hover));
  transform-origin: left center;
  animation: budget-grow 420ms ease-out;
}

@keyframes budget-grow {
  from {
    transform: scaleX(0);
  }

  to {
    transform: scaleX(1);
  }
}
