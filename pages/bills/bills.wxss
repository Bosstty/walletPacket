.filters-card {
  padding: 24rpx 28rpx;
}

.list-section {
  margin-top: 24rpx;
}

.filter-topline,
.summary-strip,
.day-header,
.bill-row,
.swipe-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.month-chip {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: var(--color-bg-card-soft);
  font-size: 28rpx;
  font-weight: 600;
}

.filter-tabs {
  margin-top: 22rpx;
  display: flex;
  gap: 16rpx;
}

.filter-tab {
  padding: 14rpx 26rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.64);
  color: var(--color-text-secondary);
  font-size: 24rpx;
  transition: all 200ms ease;
}

.filter-tab.active {
  background: var(--color-primary);
  color: #fffaf2;
}

.summary-strip {
  margin-top: 22rpx;
  color: var(--color-text-secondary);
  font-size: 22rpx;
}

.day-group:first-child {
  margin-top: 8rpx;
}

.day-group + .day-group {
  margin-top: 28rpx;
}

.day-header {
  padding-bottom: 16rpx;
}

.day-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.day-title {
  font-size: 28rpx;
  font-weight: 700;
}

.day-summary {
  color: var(--color-text-secondary);
  font-size: 22rpx;
}

.swipe-shell {
  position: relative;
  overflow: hidden;
  border-radius: 24rpx;
  background: transparent;
}

.swipe-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 200rpx;
  z-index: 1;
  opacity: 0;
  transform: translateX(18rpx);
  transition: opacity 160ms ease, transform 180ms ease;
  pointer-events: none;
  overflow: hidden;
  border-radius: 24rpx;
}

.swipe-shell.is-revealing .swipe-actions {
  opacity: 1;
  transform: translateX(0);
  pointer-events: auto;
}

.swipe-btn {
  width: 100rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #fffaf2;
}

.swipe-btn.edit {
  background: var(--color-primary-hover);
}

.swipe-btn.delete {
  background: var(--color-primary-active);
}

.bill-row {
  position: relative;
  z-index: 2;
  width: 100%;
  box-sizing: border-box;
  padding: 24rpx 22rpx;
  border: 1rpx solid rgba(47, 36, 31, 0.06);
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(251, 244, 234, 0.96), rgba(255, 250, 242, 0.98));
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
  transition: transform 180ms ease;
  gap: 20rpx;
}

.swipe-shell.is-hinting .bill-row {
  transition: transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
}

.bill-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.bill-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bill-note {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bill-amount {
  flex-shrink: 0;
  min-width: 160rpx;
  text-align: right;
  font-size: 30rpx;
  font-weight: 700;
}

.expense {
  color: var(--color-expense);
}

.income {
  color: var(--color-income);
}
