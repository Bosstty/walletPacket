.profile-card,
.settings-card {
  padding: 24rpx 28rpx;
}

.settings-card {
  margin-top: 24rpx;
}

.profile-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
}

.profile-card .section-subtitle + .section-subtitle {
  display: block;
  margin-top: 8rpx;
}

.field-row,
.row-topline,
.budget-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.field-label {
  font-size: 28rpx;
}

.action-button {
  margin-top: 22rpx;
}

.month-chip,
.picker-field,
.budget-input {
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid var(--line);
}

.month-chip,
.picker-field {
  padding: 16rpx 22rpx;
}

.budget-editor {
  margin-top: 26rpx;
}

.budget-input {
  margin-top: 16rpx;
  height: 88rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.budget-row {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid var(--line);
  font-size: 26rpx;
}
