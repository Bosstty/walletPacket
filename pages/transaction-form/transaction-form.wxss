.form-card {
  padding: 28rpx;
}

.form-intro {
  margin-bottom: 24rpx;
}

.form-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
}

.form-copy {
  display: block;
  margin-top: 10rpx;
  color: var(--color-text-secondary);
  font-size: 24rpx;
  line-height: 1.6;
}

.type-switch {
  display: flex;
  justify-content: center;
}

.switch-track {
  position: relative;
  width: 100%;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  background: var(--color-bg-card-soft);
  border-radius: 999rpx;
  padding: 8rpx;
}

.switch-indicator {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  width: calc(50% - 8rpx);
  height: calc(100% - 16rpx);
  border-radius: 999rpx;
  background: rgba(184, 92, 56, 0.14);
  transition: transform 220ms ease;
}

.switch-indicator.income {
  transform: translateX(100%);
  background: rgba(155, 108, 68, 0.14);
}

.switch-item {
  position: relative;
  z-index: 1;
  height: 76rpx;
  line-height: 76rpx;
  text-align: center;
  color: var(--color-text-secondary);
  font-size: 28rpx;
  font-weight: 600;
}

.switch-item.active {
  color: var(--color-text-primary);
}

.amount-panel {
  margin-top: 28rpx;
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.amount-prefix {
  font-size: 44rpx;
  font-weight: 700;
}

.amount-input {
  flex: 1;
  height: 100rpx;
  font-size: 64rpx;
  font-weight: 700;
}

.quick-amounts {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.quick-amount-chip,
.quick-note-chip {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid var(--color-line);
  color: var(--color-text-secondary);
  font-size: 22rpx;
}

.section {
  margin-top: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.section-tip {
  color: var(--color-text-secondary);
  font-size: 22rpx;
}

.category-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 16rpx;
}

.category-chip {
  padding: 20rpx 14rpx;
  text-align: center;
  border-radius: 24rpx;
  border: 1rpx solid var(--color-line);
  background: rgba(255, 255, 255, 0.7);
  transition: transform 180ms ease;
}

.category-chip.selected {
  background: rgba(184, 92, 56, 0.12);
  border-color: rgba(184, 92, 56, 0.24);
  transform: translateY(-4rpx);
}

.category-name {
  font-size: 24rpx;
}

.field-list {
  margin-top: 28rpx;
  border-top: 1rpx solid var(--color-line);
}

.field-row {
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid var(--color-line);
}

.field-label,
.field-value {
  font-size: 28rpx;
}

.field-value {
  color: var(--color-text-secondary);
}

.note-area {
  margin-top: 18rpx;
  width: 100%;
  min-height: 160rpx;
  padding: 22rpx;
  box-sizing: border-box;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid var(--color-line);
}

.quick-notes {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.quick-note-chip {
  background: transparent;
  border-style: dashed;
}

.save-button,
.delete-button {
  margin-top: 28rpx;
  width: 100%;
  height: 88rpx;
  min-height: 88rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  font-weight: 700;
}

.delete-button {
  border: 1rpx solid rgba(177, 79, 47, 0.18);
  background: rgba(177, 79, 47, 0.06);
  color: var(--color-danger);
  border-radius: 999rpx;
}

.custom-toggle {
  position: relative;
  width: 92rpx;
  height: 54rpx;
  padding: 6rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  background: rgba(119, 105, 95, 0.22);
  transition: background 200ms ease;
}

.custom-toggle.active {
  background: var(--color-primary);
}

.custom-toggle__thumb {
  width: 42rpx;
  height: 42rpx;
  border-radius: 21rpx;
  background: #fffaf2;
  box-shadow: 0 8rpx 16rpx rgba(47, 36, 31, 0.16);
  transition: transform 200ms ease;
}

.custom-toggle.active .custom-toggle__thumb {
  transform: translateX(38rpx);
}
