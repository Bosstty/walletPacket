.loading-card,
.budget-card,
.overview-card {
  padding: 28rpx;
}

.loading-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 16rpx;
}

.retry-button {
  margin-top: 16rpx;
}

.ledger-intro {
  padding: 8rpx 6rpx 26rpx;
}

.ledger-title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.2;
}

.ledger-copy {
  display: block;
  margin-top: 10rpx;
  color: var(--color-text-secondary);
  font-size: 24rpx;
  line-height: 1.6;
}

.overview-card {
  animation: float-in 280ms ease-out;
}

.card-topline,
.budget-row,
.transaction-row,
.quick-actions {
  display: flex;
  align-items: center;
}

.card-topline {
  justify-content: space-between;
}

.segment-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.segment-control {
  display: flex;
  padding: 8rpx;
  border-radius: var(--radius-chip);
  background: var(--color-bg-card-soft);
}

.segment-item {
  min-width: 118rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: var(--radius-chip);
  color: var(--color-text-secondary);
  font-size: 25rpx;
  font-weight: 600;
  transition: all 220ms ease;
}

.segment-item.active {
  background: var(--color-primary);
  color: #fffaf2;
  box-shadow: 0 10rpx 24rpx rgba(184, 92, 56, 0.16);
}

.overview-hint {
  color: var(--color-text-tertiary);
  font-size: 22rpx;
}

.overview-body {
  margin-top: 28rpx;
}

.overview-date,
.overview-label,
.overview-amount {
  display: block;
}

.overview-date {
  color: var(--color-text-secondary);
  font-size: 24rpx;
}

.overview-label {
  margin-top: 14rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.overview-amount {
  display: block;
  margin-top: 8rpx;
  font-size: 72rpx;
}

.overview-metrics {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.quick-actions {
  gap: 20rpx;
  margin-top: 24rpx;
}

.action-wrap {
  flex: 1;
}

.budget-card,
.list-section {
  margin-top: 24rpx;
}

.budget-ratio,
.list-link {
  color: var(--color-primary);
  font-size: 24rpx;
  font-weight: 600;
}

.budget-row {
  justify-content: space-between;
  margin-top: 18rpx;
}

.budget-label {
  color: var(--color-text-secondary);
  font-size: 24rpx;
}

.empty-state {
  padding: 32rpx 0 8rpx;
}

.recent-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.transaction-row {
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 22rpx;
  border: 1rpx solid rgba(47, 36, 31, 0.06);
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(251, 244, 234, 0.96), rgba(255, 250, 242, 0.98));
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
}

.transaction-main,
.transaction-side {
  display: flex;
  flex-direction: column;
}

.transaction-main {
  flex: 1;
  min-width: 0;
}

.transaction-side {
  flex-shrink: 0;
  align-items: flex-end;
}

.transaction-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.transaction-note,
.transaction-time {
  margin-top: 8rpx;
  color: var(--color-text-secondary);
  font-size: 22rpx;
}

.transaction-note {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.transaction-amount {
  font-size: 30rpx;
  font-weight: 700;
}

.expense {
  color: var(--color-expense);
}

.income {
  color: var(--color-income);
}

@keyframes float-in {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}
